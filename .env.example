# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# Supabase — Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your actual password
SUPABASE_DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres

# Which LLM powers the agent: "gemini" (free AI Studio) or "ollama" (fully local)
LLM_PROVIDER=gemini

# Google Gemini — aistudio.google.com → Get API key (free tier). Should start with AIza...
GEMINI_API_KEY=AIza...

# Local Ollama agent model (only used when LLM_PROVIDER=ollama; needs llama3.1+ for tools)
OLLAMA_CHAT_MODEL=llama3.1

# Upstash Redis — upstash.com → your Redis DB → REST API tab
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Ollama — runs locally for embeddings; host.docker.internal inside Docker
OLLAMA_BASE_URL=http://localhost:11434
